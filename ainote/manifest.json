{
  "manifest_version": 3,
  "name": "AINote Markdown Renderer",
  "version": "1.3.0",
  "description": "自动渲染 .md/.drawio/.ipynb/.csv/.geojson/.adoc/.json 文件，支持 Mermaid/PlantUML/D2/Graphviz/WaveDrom/Nomnoml/Vega 图表、KaTeX 公式、代码高亮、导出 PDF、编辑器模式",
  "icons": {
    "16": "icon16.svg",
    "48": "icon48.svg",
    "128": "icon128.svg"
  },
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AINote Markdown Renderer"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "renderers/renderer-registry.js",
        "renderers/render-pipeline.js",
        "renderers/renderer-mermaid.js",
        "renderers/renderer-plantuml.js",
        "renderers/renderer-graphviz.js",
        "renderers/renderer-d2.js",
        "renderers/renderer-katex.js",
        "renderers/renderer-hljs.js",
        "renderers/renderer-wavedrom.js",
        "renderers/renderer-nomnoml.js",
        "renderers/renderer-vega.js",
        "renderers/renderer-ipynb.js",
        "renderers/renderer-csv.js",
        "renderers/renderer-geojson.js",
        "renderers/renderer-adoc.js",
        "renderers/renderer-json.js",
        "content.js"
      ],
      "css": ["styles/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "bridge.js",
        "lib/*",
        "lib/languages/*",
        "lib/styles/*",
        "lib/fonts/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
